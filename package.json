{
  "name": "barcode-app",
  "version": "1.0.0",
  "description": "MPCL - Impresion de codigos de barra",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "electron:build": "electron-vite build && electron-builder"
  },
  "build": {
    "appId": "com.mpcl.barcode",
    "productName": "MPCL Barcode",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ]
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-select": "^2.1.4",
    "bwip-js": "^4.5.1",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.0.0",
    "esbuild": "^0.28.0"
  }
}
